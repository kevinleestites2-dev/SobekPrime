# SobekPrime — Environment Configuration
# Copy to .env and fill in your keys

# ── TRADING MODE ──────────────────────────────
SIMULATE_MODE=true           # true = paper trading | false = LIVE (real money)
SOBEK_CAPITAL=1000.0         # Starting capital in USDT
CYCLE_INTERVAL=300           # Main loop interval in seconds (300 = 5 min)

# ── EXCHANGE API KEYS ─────────────────────────
BINANCE_API_KEY=
BINANCE_SECRET=

BYBIT_API_KEY=
BYBIT_SECRET=

OKX_API_KEY=
OKX_SECRET=
OKX_PASSPHRASE=

KRAKEN_API_KEY=
KRAKEN_SECRET=

# ── TELEGRAM (inherited from ZeusPrime) ───────
TELEGRAM_BOT_TOKEN=8679655550:AAGUB1m5fmqHc8OHqqM24Vixz8FfwX-gqD4
TELEGRAM_CHAT_ID=7135054241

# ── RISK PARAMETERS ───────────────────────────
STOP_LOSS_PCT=0.02           # 2% stop loss per trade
TAKE_PROFIT_PCT=0.04         # 4% take profit per trade
TRAILING_STOP_PCT=0.02       # Trailing stop activates at 2% profit
MAX_POSITIONS=5              # Max simultaneous open positions
DAILY_LOSS_LIMIT=0.05        # 5% daily loss = full stop
MAX_DRAWDOWN=0.10            # 10% total drawdown = Sobek sleeps
CONSEC_LOSS_PAUSE=3          # 3 consecutive losses = strategy paused 24h
BLACK_SWAN_PCT=0.15          # BTC drops 15%/1h = close everything
VOL_REDUCTION=0.50           # Volatility spike = reduce position sizes 50%
MAX_DCA_LAYERS=6             # Maximum DCA martingale layers
